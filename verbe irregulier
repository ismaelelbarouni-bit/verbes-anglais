<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Jeux Verbes Irréguliers 🎮</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#07070f;--surf:#0f0f1e;--surf2:#16162a;--bord:#1e1e38;
  --c1:#ff4757;--c2:#2ed573;--c3:#ffa502;--c4:#1e90ff;
  --c5:#ff6b81;--c6:#eccc68;--c7:#7bed9f;--c8:#a29bfe;
  --tx:#f1f2f6;--dim:#57577a;
  --fh:'Syne',sans-serif;--fm:'JetBrains Mono',monospace;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
body{background:var(--bg);color:var(--tx);font-family:var(--fh);min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background:radial-gradient(ellipse 70% 40% at 15% 5%,rgba(30,144,255,.07) 0%,transparent 60%),
    radial-gradient(ellipse 50% 35% at 85% 95%,rgba(255,71,87,.06) 0%,transparent 60%);}

/* NAV */
nav{position:sticky;top:0;z-index:100;background:rgba(7,7,15,.93);backdrop-filter:blur(20px);border-bottom:1px solid var(--bord);padding:10px 14px;}
.nav-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.logo{font-size:clamp(13px,2.5vw,18px);font-weight:900;letter-spacing:-1px;white-space:nowrap;flex-shrink:0;}
.logo span{color:var(--c1);}
.nav-games{display:flex;gap:5px;overflow-x:auto;scrollbar-width:none;flex:1;-webkit-overflow-scrolling:touch;}
.nav-games::-webkit-scrollbar{display:none;}
.nb{flex-shrink:0;padding:6px 11px;background:var(--surf2);border:1px solid var(--bord);border-radius:16px;font-family:var(--fh);font-size:clamp(10px,1.7vw,12px);font-weight:700;color:var(--dim);cursor:pointer;transition:all .2s;white-space:nowrap;}
.nb:hover{color:var(--tx);}
.nb.active{color:#fff;}
.nb0.active{background:var(--surf2);border-color:var(--dim);color:var(--tx);}
.nb1.active{background:var(--c1);border-color:var(--c1);}
.nb2.active{background:var(--c2);border-color:var(--c2);color:#000;}
.nb3.active{background:var(--c3);border-color:var(--c3);color:#000;}
.nb4.active{background:var(--c4);border-color:var(--c4);}
.nb5.active{background:var(--c8);border-color:var(--c8);color:#000;}
.nb6.active{background:var(--c5);border-color:var(--c5);}
.nb7.active{background:var(--c6);border-color:var(--c6);color:#000;}
.nb8.active{background:var(--c7);border-color:var(--c7);color:#000;}

/* SCREENS */
.screen{display:none;position:relative;z-index:1;max-width:1200px;margin:0 auto;padding:18px 14px 70px;}
.screen.active{display:block;}

/* HOME */
.home-hero{text-align:center;padding:26px 0 36px;}
.home-hero h1{font-size:clamp(36px,9vw,82px);font-weight:900;line-height:.9;letter-spacing:-3px;margin-bottom:12px;}
.g{background:linear-gradient(135deg,var(--c4),var(--c8),var(--c1));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.home-hero p{color:var(--dim);font-family:var(--fm);font-size:12px;max-width:460px;margin:0 auto 12px;line-height:1.9;}
.sync-notice{display:inline-flex;align-items:center;gap:8px;background:rgba(162,155,254,.1);border:1px solid rgba(162,155,254,.3);border-radius:20px;padding:8px 16px;font-family:var(--fm);font-size:11px;color:var(--c8);margin-bottom:30px;}
.games-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,250px),1fr));gap:13px;}
.gc{background:var(--surf);border:1px solid var(--bord);border-radius:16px;padding:22px 18px;cursor:pointer;transition:transform .2s,border-color .2s,box-shadow .2s;position:relative;overflow:hidden;}
.gc:hover{transform:translateY(-4px);box-shadow:0 14px 48px rgba(0,0,0,.5);}
.gc1:hover{border-color:var(--c1);} .gc2:hover{border-color:var(--c2);} .gc3:hover{border-color:var(--c3);} .gc4:hover{border-color:var(--c4);} .gc5:hover{border-color:var(--c8);} .gc6:hover{border-color:var(--c5);} .gc7:hover{border-color:var(--c6);} .gc8:hover{border-color:var(--c7);}
.gc .gi{font-size:34px;margin-bottom:10px;}
.gc .gt{font-family:var(--fm);font-size:9px;letter-spacing:3px;text-transform:uppercase;margin-bottom:6px;font-weight:700;}
.gc1 .gt{color:var(--c1);}.gc2 .gt{color:var(--c2);}.gc3 .gt{color:var(--c3);}.gc4 .gt{color:var(--c4);}.gc5 .gt{color:var(--c8);}.gc6 .gt{color:var(--c5);}.gc7 .gt{color:var(--c6);}.gc8 .gt{color:var(--c7);}
.gc h3{font-size:clamp(15px,3vw,19px);font-weight:800;margin-bottom:6px;}
.gc p{font-family:var(--fm);font-size:11px;color:var(--dim);line-height:1.65;}
.pb{margin-top:12px;display:inline-block;padding:7px 16px;border-radius:9px;font-family:var(--fh);font-weight:700;font-size:12px;}
.gc1 .pb{background:var(--c1);color:#fff;}.gc2 .pb{background:var(--c2);color:#000;}.gc3 .pb{background:var(--c3);color:#000;}.gc4 .pb{background:var(--c4);color:#fff;}.gc5 .pb{background:var(--c8);color:#000;}.gc6 .pb{background:var(--c5);color:#fff;}.gc7 .pb{background:var(--c6);color:#000;}.gc8 .pb{background:var(--c7);color:#000;}

/* SHARED */
.gh{display:flex;align-items:center;gap:10px;margin-bottom:18px;flex-wrap:wrap;}
.bk{padding:7px 13px;background:var(--surf2);border:1px solid var(--bord);border-radius:9px;font-family:var(--fh);font-weight:700;font-size:12px;color:var(--dim);cursor:pointer;transition:all .2s;flex-shrink:0;}
.bk:hover{color:var(--tx);}
.gtit{font-size:clamp(17px,4vw,26px);font-weight:900;letter-spacing:-1px;}
.gs{display:flex;gap:7px;margin-left:auto;flex-wrap:wrap;}
.sc{padding:5px 11px;background:var(--surf2);border:1px solid var(--bord);border-radius:16px;font-family:var(--fm);font-size:11px;color:var(--dim);}
.sc span{font-weight:700;}
.bpri{padding:11px 24px;border:none;border-radius:11px;font-family:var(--fh);font-weight:800;font-size:14px;cursor:pointer;transition:all .2s;}
.bpri:hover{transform:translateY(-2px);}
.bgho{padding:10px 20px;background:var(--surf2);border:1px solid var(--bord);border-radius:11px;font-family:var(--fh);font-weight:700;font-size:13px;color:var(--dim);cursor:pointer;transition:all .2s;}
.bgho:hover{color:var(--tx);border-color:var(--dim);}
.pbar{height:4px;background:var(--surf2);border-radius:4px;margin-bottom:18px;overflow:hidden;}
.pfill{height:100%;border-radius:4px;transition:width .3s;}
.mb{padding:7px 15px;background:var(--surf2);border:1px solid var(--bord);border-radius:16px;font-family:var(--fm);font-size:11px;color:var(--dim);cursor:pointer;transition:all .2s;}
.mb.active{background:var(--c8);border-color:var(--c8);color:#000;}
.mb:hover:not(.active){border-color:var(--dim);color:var(--tx);}

/* BOTH FORMS BADGE — clé du concept */
.both-badge{
  display:inline-flex;align-items:center;gap:6px;
  background:rgba(162,155,254,.12);border:1px solid rgba(162,155,254,.4);
  border-radius:20px;padding:5px 12px;font-family:var(--fm);font-size:10px;color:var(--c8);
  margin-bottom:14px;letter-spacing:1px;
}
/* Two-form input group */
.two-forms{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.form-field{display:flex;flex-direction:column;gap:5px;}
.form-field label{font-family:var(--fm);font-size:9px;letter-spacing:2px;color:var(--dim);text-transform:uppercase;}
.qinp{width:100%;padding:12px 14px;background:var(--bg);border:2px solid var(--bord);border-radius:11px;color:var(--tx);font-family:var(--fm);font-size:13px;outline:none;transition:border-color .2s;text-align:center;}
.qinp:focus{border-color:var(--c8);}
.qinp.ok{border-color:var(--c2);color:var(--c2);}
.qinp.ko{border-color:var(--c1);color:var(--c1);}

/* TOAST */
.toast{position:fixed;top:70px;left:50%;transform:translateX(-50%) translateY(-14px);background:var(--surf2);border:1px solid var(--bord);border-radius:11px;padding:8px 16px;font-family:var(--fm);font-size:12px;z-index:300;opacity:0;transition:all .25s;pointer-events:none;white-space:nowrap;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
.toast.ok{border-color:var(--c2);color:var(--c2);}
.toast.ko{border-color:var(--c1);color:var(--c1);}

/* RESULT */
.rov{position:fixed;inset:0;background:rgba(7,7,15,.96);z-index:200;display:none;align-items:center;justify-content:center;padding:20px;}
.rov.show{display:flex;}
.rbox{background:var(--surf);border:2px solid var(--bord);border-radius:22px;padding:clamp(26px,6vw,50px);text-align:center;max-width:440px;width:100%;}
.rbox .rn{font-size:clamp(58px,13vw,94px);font-weight:900;line-height:1;}
.rbox .rl{font-family:var(--fm);font-size:12px;color:var(--dim);margin:7px 0 20px;}
.racts{display:flex;gap:9px;flex-wrap:wrap;justify-content:center;}

/* ══ FLASH ══ */
.flash-area{display:flex;flex-direction:column;align-items:center;gap:16px;}
.flash-mode-btns{display:flex;gap:7px;flex-wrap:wrap;justify-content:center;}
.fcard{width:100%;max-width:520px;min-height:clamp(190px,36vw,270px);background:var(--surf);border:2px solid var(--bord);border-radius:20px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:border-color .3s;position:relative;overflow:hidden;perspective:1000px;}
.fcard:hover{border-color:var(--c1);}
.fc-f,.fc-b{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:20px;backface-visibility:hidden;transition:transform .4s;}
.fc-b{transform:rotateY(180deg);}
.fcard.flipped .fc-f{transform:rotateY(-180deg);}
.fcard.flipped .fc-b{transform:rotateY(0);}
.fc-prompt{font-family:var(--fm);font-size:9px;letter-spacing:3px;color:var(--dim);text-transform:uppercase;margin-bottom:10px;}
.fc-word{font-size:clamp(24px,6vw,42px);font-weight:900;color:var(--c1);letter-spacing:-1px;text-align:center;}
.fc-sub{font-family:var(--fm);font-size:10px;color:var(--dim);margin-top:6px;text-align:center;}
/* answer shows BOTH forms prominently */
.fc-ans{text-align:center;width:100%;}
.fc-ans .fa-inf{font-size:clamp(16px,3.5vw,24px);font-weight:900;color:var(--c2);margin-bottom:12px;}
.fc-ans .fa-pair{display:grid;grid-template-columns:1fr 1fr;gap:10px;width:100%;}
.fa-box{padding:10px;background:var(--bg);border-radius:10px;border:1px solid var(--bord);}
.fa-box .fl{font-family:var(--fm);font-size:8px;letter-spacing:2px;color:var(--dim);text-transform:uppercase;margin-bottom:5px;}
.fa-box .fv{font-family:var(--fm);font-size:clamp(13px,2.5vw,16px);font-weight:700;}
.fa-box.pret .fv{color:var(--c3);}
.fa-box.pp .fv{color:var(--c5);}
.fc-fr{font-family:var(--fm);font-size:10px;color:var(--dim);margin-top:10px;}
.rbtns{display:flex;gap:9px;flex-wrap:wrap;justify-content:center;}
.fnav{display:flex;align-items:center;gap:12px;}
.fnav button{width:40px;height:40px;border-radius:50%;background:var(--surf2);border:1px solid var(--bord);color:var(--tx);font-size:15px;cursor:pointer;transition:all .2s;}
.fnav button:hover{background:var(--c1);border-color:var(--c1);}
.fctr{font-family:var(--fm);font-size:12px;color:var(--dim);}
.fctr span{color:var(--tx);font-weight:700;}

/* ══ ASSOCIATION ══ */
.assoc-container{max-width:900px;margin:0 auto;}
.assoc-top{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-bottom:14px;}
.assoc-timer{font-size:clamp(26px,6vw,44px);font-weight:900;color:var(--c3);font-family:var(--fm);}
.assoc-timer.danger{color:var(--c1);animation:pulse .5s infinite alternate;}
@keyframes pulse{from{opacity:1}to{opacity:.4}}
.assoc-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.assoc-col{display:flex;flex-direction:column;gap:7px;}
.col-title{font-family:var(--fm);font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--dim);text-align:center;margin-bottom:3px;}
/* Each item shows BOTH prét+pp when relevant */
.aitem{padding:clamp(9px,2vw,13px);background:var(--surf);border:2px solid var(--bord);border-radius:11px;cursor:pointer;transition:all .15s;text-align:center;user-select:none;}
.aitem:hover{border-color:var(--c3);}
.aitem.sel{border-color:var(--c3);background:rgba(255,165,2,.1);}
.aitem.matched{border-color:var(--c2);background:rgba(46,213,115,.08);cursor:default;animation:pop .3s ease;}
.aitem.wrong{border-color:var(--c1);background:rgba(255,71,87,.08);animation:shake .3s;}
@keyframes pop{0%{transform:scale(.95)}60%{transform:scale(1.05)}100%{transform:scale(1)}}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-5px)}75%{transform:translateX(5px)}}
.aitem .am{font-family:var(--fm);font-size:clamp(12px,2vw,14px);font-weight:700;color:var(--tx);}
.aitem .ap{font-family:var(--fm);font-size:9px;color:var(--dim);margin-top:3px;}/* sub: both forms */
.aitem.matched .am{color:var(--c2);}
.aitem.matched .ap{color:rgba(46,213,115,.5);}
.assoc-mbts{display:flex;gap:7px;flex-wrap:wrap;justify-content:center;margin-bottom:18px;}
.assoc-start{text-align:center;padding:36px 20px;}

/* ══ SNIPER ══ */
.sn-arena{width:100%;height:clamp(300px,50vw,440px);background:var(--surf);border:2px solid var(--bord);border-radius:16px;overflow:hidden;position:relative;margin-bottom:12px;}
.sn-arena::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;background:var(--c1);box-shadow:0 0 14px var(--c1);}
/* Falling item shows BOTH forms */
.fw{position:absolute;top:-70px;background:var(--surf2);border:1px solid var(--bord);border-radius:10px;padding:6px 12px;cursor:pointer;transition:background .1s;white-space:nowrap;text-align:center;}
.fw:hover{background:rgba(30,144,255,.3);}
.fw .fw-pret{font-family:var(--fm);font-size:clamp(11px,2vw,13px);font-weight:700;color:var(--tx);}
.fw .fw-pp{font-family:var(--fm);font-size:9px;color:var(--dim);}
.sn-target-area{background:var(--surf);border:2px solid var(--bord);border-radius:13px;padding:14px;text-align:center;margin-bottom:11px;}
.sn-target{font-size:clamp(20px,5vw,36px);font-weight:900;color:var(--c4);}
.sn-sub{font-family:var(--fm);font-size:10px;color:var(--dim);margin-top:3px;}
.sn-stats{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;}
.ss{padding:7px 13px;background:var(--surf2);border:1px solid var(--bord);border-radius:16px;font-family:var(--fm);font-size:11px;color:var(--dim);}
.ss span{font-weight:700;}

/* ══ MEMORY ══ */
.mem-ctrl{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:16px;align-items:center;}
.mgrid{display:grid;gap:8px;width:100%;}
.mgrid.g4{grid-template-columns:repeat(4,1fr);}
.mgrid.g8{grid-template-columns:repeat(4,1fr);}
@media(min-width:600px){.mgrid.g8{grid-template-columns:repeat(8,1fr);}}
.mgrid.g12{grid-template-columns:repeat(4,1fr);}
@media(min-width:600px){.mgrid.g12{grid-template-columns:repeat(6,1fr);}}
.mcard{aspect-ratio:3/4;background:var(--surf2);border:2px solid var(--bord);border-radius:10px;cursor:pointer;transition:transform .3s;position:relative;transform-style:preserve-3d;}
.mcard:hover{border-color:var(--c8);}
.mcard.flipped,.mcard.matched{transform:rotateY(180deg);}
.mf,.mb{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;padding:4px;border-radius:8px;backface-visibility:hidden;text-align:center;}
.mf{background:var(--surf2);}
.mf .mi{font-size:24px;}
.mb{background:var(--surf);border:2px solid var(--c8);transform:rotateY(180deg);}
.mb .mct{font-family:var(--fm);font-size:7px;letter-spacing:2px;color:var(--dim);text-transform:uppercase;margin-bottom:3px;}
/* When type=pair show BOTH pret+pp stacked */
.mb .mcv{font-family:var(--fm);font-size:clamp(9px,1.7vw,12px);font-weight:700;color:var(--tx);line-height:1.4;}
.mb .mcv .pret-c{color:var(--c3);}
.mb .mcv .pp-c{color:var(--c5);font-size:.85em;}
.mcard.matched .mb{background:rgba(46,213,115,.1);border-color:var(--c2);}

/* ══ CHAIN ══ */
.chain-area{max-width:640px;margin:0 auto;}
.cvd{background:var(--surf);border:2px solid var(--bord);border-radius:16px;padding:22px;text-align:center;margin-bottom:16px;}
.cvl{font-family:var(--fm);font-size:9px;letter-spacing:3px;color:var(--dim);text-transform:uppercase;margin-bottom:9px;}
.cvw{font-size:clamp(26px,6vw,46px);font-weight:900;color:var(--c8);letter-spacing:-2px;}
.cvf{font-family:var(--fm);font-size:11px;color:var(--dim);margin-top:4px;}
.ch-slots{display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px;margin-bottom:16px;}
@media(max-width:460px){.ch-slots{grid-template-columns:1fr;}}
.cslot{padding:12px 8px;background:var(--surf);border:2px dashed var(--bord);border-radius:12px;text-align:center;min-height:62px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;transition:all .2s;}
.cslot.drag-over{border-color:var(--c8);background:rgba(162,155,254,.08);}
.cslot.filled{border-style:solid;border-color:var(--c8);}
.cslot.correct{border-color:var(--c2);background:rgba(46,213,115,.07);}
.cslot.wrong{border-color:var(--c1);background:rgba(255,71,87,.07);}
.sl{font-family:var(--fm);font-size:8px;letter-spacing:2px;color:var(--dim);text-transform:uppercase;}
.sv{font-family:var(--fm);font-size:clamp(11px,2.5vw,14px);font-weight:700;color:var(--tx);}
.ctiles{display:flex;gap:7px;flex-wrap:wrap;justify-content:center;margin-bottom:13px;}
/* tile shows BOTH forms when it's the pret/pp pair */
.ctile{padding:8px 14px;background:var(--surf2);border:2px solid var(--bord);border-radius:9px;font-family:var(--fm);font-size:clamp(10px,2vw,13px);font-weight:700;cursor:grab;transition:all .2s;color:var(--tx);user-select:none;text-align:center;}
.ctile:hover{border-color:var(--c8);}
.ctile.selected{border-color:var(--c8);background:rgba(162,155,254,.18);}
.ctile.used{opacity:.3;cursor:not-allowed;}
.ctile .ct-sub{font-size:8px;color:var(--dim);font-weight:400;margin-top:2px;}
.ch-btns{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;}

/* ══ TRADUCTEUR ══ */
.trans-area{max-width:540px;margin:0 auto;}
.tcard{background:var(--surf);border:2px solid var(--bord);border-radius:20px;padding:clamp(18px,4vw,36px);text-align:center;margin-bottom:16px;}
.tdir{display:inline-flex;gap:6px;align-items:center;background:var(--surf2);border:1px solid var(--bord);border-radius:16px;padding:5px 13px;font-family:var(--fm);font-size:10px;color:var(--dim);margin-bottom:16px;letter-spacing:1px;}
.tql{font-family:var(--fm);font-size:9px;letter-spacing:3px;color:var(--dim);text-transform:uppercase;margin-bottom:8px;}
.tq{font-size:clamp(24px,6vw,44px);font-weight:900;color:var(--c5);letter-spacing:-1px;margin-bottom:4px;}
.th{font-family:var(--fm);font-size:10px;color:var(--dim);margin-bottom:18px;}
.tfields{display:flex;flex-direction:column;gap:9px;}
.tfield label{font-family:var(--fm);font-size:8px;letter-spacing:2px;color:var(--dim);text-transform:uppercase;display:block;margin-bottom:4px;}
.tinp{width:100%;padding:11px 13px;background:var(--bg);border:2px solid var(--bord);border-radius:11px;color:var(--tx);font-family:var(--fm);font-size:13px;outline:none;transition:border-color .2s;}
.tinp:focus{border-color:var(--c5);}
.tinp.ok{border-color:var(--c2);color:var(--c2);}
.tinp.ko{border-color:var(--c1);color:var(--c1);}
.tacts{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-top:13px;}
.tfb{font-family:var(--fm);font-size:11px;margin-top:11px;min-height:16px;display:flex;gap:12px;flex-wrap:wrap;justify-content:center;}
.tfb span{color:var(--dim);}
.tfb strong{color:var(--c2);}
.tsc{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-bottom:16px;}
.tc{padding:6px 13px;background:var(--surf2);border:1px solid var(--bord);border-radius:16px;font-family:var(--fm);font-size:11px;color:var(--dim);}
.tc .good{color:var(--c2);font-weight:700;} .tc .bad{color:var(--c1);font-weight:700;}

/* ══ QCM ══ */
.qcm-area{max-width:640px;margin:0 auto;}
.qcard{background:var(--surf);border:2px solid var(--bord);border-radius:20px;padding:clamp(20px,5vw,38px);text-align:center;margin-bottom:18px;}
.ql{font-family:var(--fm);font-size:9px;letter-spacing:3px;color:var(--dim);text-transform:uppercase;margin-bottom:10px;}
.qq{font-size:clamp(26px,7vw,52px);font-weight:900;color:var(--c6);letter-spacing:-2px;margin-bottom:5px;}
.qh{font-family:var(--fm);font-size:11px;color:var(--dim);margin-bottom:22px;}
/* QCM choices show BOTH pret+pp */
.qchoices{display:grid;grid-template-columns:1fr 1fr;gap:9px;}
.qch{padding:clamp(12px,3vw,18px) 10px;background:var(--surf2);border:2px solid var(--bord);border-radius:13px;cursor:pointer;transition:all .18s;text-align:center;display:flex;flex-direction:column;align-items:center;gap:4px;}
.qch:hover:not(.dis){border-color:var(--c6);background:rgba(236,204,104,.07);}
.qch.correct{border-color:var(--c2);background:rgba(46,213,115,.1);}
.qch.wrong{border-color:var(--c1);background:rgba(255,71,87,.1);}
.qch.dis{cursor:default;}
/* inside choice: big pret + small pp */
.qch .ch-pret{font-family:var(--fm);font-size:clamp(13px,2.5vw,16px);font-weight:700;color:var(--tx);}
.qch .ch-pp{font-family:var(--fm);font-size:10px;color:var(--dim);margin-top:2px;}
.qch.correct .ch-pret{color:var(--c2);}
.qch.correct .ch-pp{color:rgba(46,213,115,.6);}
.qch.wrong .ch-pret{color:var(--c1);}
.qsc{display:flex;gap:9px;flex-wrap:wrap;justify-content:center;margin-bottom:18px;}
.qmodes{display:flex;gap:7px;flex-wrap:wrap;justify-content:center;margin-top:11px;}

/* ══ PENDU ══ */
.pendu-area{max-width:600px;margin:0 auto;}
.pd-modes{display:flex;gap:7px;flex-wrap:wrap;justify-content:center;margin-bottom:14px;}
.pd-stats{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-bottom:14px;}
.pd-hint{background:var(--surf);border:2px solid var(--bord);border-radius:16px;padding:20px;text-align:center;margin-bottom:16px;}
.pdl{font-family:var(--fm);font-size:9px;letter-spacing:3px;color:var(--dim);text-transform:uppercase;margin-bottom:8px;}
.pdfr{font-size:clamp(20px,5vw,34px);font-weight:900;color:var(--c7);letter-spacing:-1px;}
.pdex{font-family:var(--fm);font-size:10px;color:var(--dim);margin-top:5px;}
/* PENDU shows KNOWN partner form as hint */
.pd-partner{display:inline-flex;align-items:center;gap:6px;background:rgba(123,237,159,.1);border:1px solid rgba(123,237,159,.3);border-radius:14px;padding:5px 12px;font-family:var(--fm);font-size:11px;color:var(--c7);margin-top:8px;}
.pd-fig{text-align:center;margin-bottom:16px;}
.pd-svg{width:clamp(110px,22vw,160px);height:auto;}
.pd-word{display:flex;gap:5px;justify-content:center;flex-wrap:wrap;margin-bottom:20px;}
.pl{width:clamp(22px,5.5vw,36px);height:clamp(26px,6.5vw,42px);border-bottom:3px solid var(--dim);display:flex;align-items:flex-end;justify-content:center;font-family:var(--fm);font-size:clamp(14px,3.5vw,22px);font-weight:700;padding-bottom:2px;transition:all .2s;}
.pl.rev{border-color:var(--c2);color:var(--c2);}
.pl.wrev{border-color:var(--c1);color:var(--c1);}
.pl.sp{border:none;width:12px;}
.pd-kb{display:flex;gap:5px;flex-wrap:wrap;justify-content:center;margin-bottom:14px;max-width:500px;margin-left:auto;margin-right:auto;}
.pk{width:clamp(26px,6.5vw,38px);height:clamp(30px,7.5vw,42px);background:var(--surf2);border:1px solid var(--bord);border-radius:7px;font-family:var(--fm);font-size:clamp(10px,2.5vw,13px);font-weight:700;cursor:pointer;transition:all .15s;color:var(--tx);}
.pk:hover:not(.uok):not(.uko){background:var(--c7);border-color:var(--c7);color:#000;}
.pk.uok{background:rgba(123,237,159,.14);border-color:var(--c7);color:var(--c7);cursor:default;}
.pk.uko{background:rgba(255,71,87,.1);border-color:var(--c1);color:var(--c1);cursor:default;}

@media(max-width:500px){
  .two-forms{grid-template-columns:1fr;}
  .qchoices{grid-template-columns:1fr;}
  .assoc-grid{grid-template-columns:1fr;}
}
</style>
