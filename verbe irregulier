// ═════════ ASSOCIATION ═════════
let aMode='inf-both',aSel=null,aMatched=0,aErrors=0,aTmr=null,aStart=null,aTotal=10;
function setAM(m,el){aMode=m;document.querySelectorAll('.assoc-mbts .mb').forEach(b=>b.classList.remove('active'));el.classList.add('active');}
function stopAssoc(){clearInterval(aTmr);aTmr=null;}
function startAssoc(){
  stopAssoc();
  document.getElementById('assoc-start').style.display='none';
  document.getElementById('assoc-game').style.display='block';
  aMatched=0;aErrors=0;aSel=null;
  const m=aMode==='mix'?['inf-both','fr-both','fr-inf'][Math.floor(Math.random()*3)]:aMode;
  const sample=shuf([...V]).slice(0,aTotal);
  let leftItems,rightItems,lt,rt;
  if(m==='inf-both'){
    lt='INFINITIF'; rt='PRÉTÉRIT + PP';
    leftItems=sample.map(v=>({pairId:v.i,mainText:v.i.replace('to ',''),subText:v.fr}));
    // RIGHT shows BOTH forms together
    rightItems=shuf(sample.map(v=>({pairId:v.i,mainText:p1(v.p),subText:'PP: '+p1(v.pp)})));
  } else if(m==='fr-both'){
    lt='FRANÇAIS'; rt='PRÉTÉRIT + PP';
    leftItems=sample.map(v=>({pairId:v.i,mainText:v.fr,subText:v.i}));
    rightItems=shuf(sample.map(v=>({pairId:v.i,mainText:p1(v.p),subText:'PP: '+p1(v.pp)})));
  } else {
    lt='FRANÇAIS'; rt='INFINITIF ANGLAIS';
    leftItems=sample.map(v=>({pairId:v.i,mainText:v.fr,subText:''}));
    rightItems=shuf(sample.map(v=>({pairId:v.i,mainText:v.i,subText:p1(v.p)+' / '+p1(v.pp)})));
  }
  document.getElementById('a-ltit').textContent=lt;document.getElementById('a-rtit').textContent=rt;
  document.getElementById('a-tot').textContent=aTotal;document.getElementById('a-found').textContent=0;document.getElementById('a-err').textContent=0;
  renderACol('a-left',leftItems,'L');renderACol('a-right',rightItems,'R');
  aStart=Date.now();aTmr=setInterval(()=>{document.getElementById('a-timer').textContent=((Date.now()-aStart)/1000).toFixed(1)+'s';},100);
}
function renderACol(id,items,side){
  const col=document.getElementById(id);col.innerHTML='';
  items.forEach(item=>{
    const d=document.createElement('div');d.className='aitem';d.dataset.pid=item.pairId;d.dataset.side=side;
    d.innerHTML=`<div class="am">${item.mainText}</div>${item.subText?`<div class="ap">${item.subText}</div>`:''}`;
    d.onclick=()=>aClick(d);col.appendChild(d);
  });
}
function aClick(el){
  if(el.classList.contains('matched'))return;
  const side=el.dataset.side;
  if(!aSel){
    document.querySelectorAll(side==='L'?'#a-left .aitem':'#a-right .aitem').forEach(e=>e.classList.remove('sel'));
    el.classList.add('sel');aSel={el,side,pid:el.dataset.pid};
  } else {
    if(aSel.side===side){document.querySelectorAll('.aitem.sel').forEach(e=>e.classList.remove('sel'));el.classList.add('sel');aSel={el,side,pid:el.dataset.pid};return;}
    const ok=aSel.pid===el.dataset.pid;
    [aSel.el,el].forEach(e=>{
      e.classList.remove('sel');
      if(ok)e.classList.add('matched');
      else{e.classList.add('wrong');setTimeout(()=>e.classList.remove('wrong','sel'),700);}
    });
    if(ok){aMatched++;document.getElementById('a-found').textContent=aMatched;toast('✅ Paire !','ok');
      if(aMatched===aTotal){stopAssoc();const t=((Date.now()-aStart)/1000).toFixed(1);showR(t+'s','pour tout associer 🎉 ('+aErrors+' erreur'+(aErrors>1?'s':'')+')',startAssoc,'var(--c2)');}
    } else {aErrors++;document.getElementById('a-err').textContent=aErrors;toast('❌ Faux !','ko');}
    aSel=null;
  }
}

// ═════════ SNIPER ═════════
let snD=[],snI=0,snSc=0,snLv=3,snInv=null,snFIs=[],snV=null;
function startSniper(){
  snFIs.forEach(clearInterval);snFIs=[];
  document.getElementById('sn-arena').innerHTML='';
  snD=shuf([...V]);snI=0;snSc=0;snLv=3;document.getElementById('sn-sc').textContent=0;updSnLv();nextSn();
  snInv=setInterval(spawnSn,2100);
}
function stopSniper(){clearInterval(snInv);snInv=null;snFIs.forEach(clearInterval);snFIs=[];}
function updSnLv(){document.getElementById('sn-lc').textContent='❤️'.repeat(snLv)||'💀';}
function nextSn(){if(snI>=snD.length)snD=shuf([...V]),snI=0;snV=snD[snI++];document.getElementById('sn-tg').textContent=snV.i;document.getElementById('sn-sb').textContent=snV.fr;}
function spawnSn(){
  if(!snV||!snInv)return;
  const arena=document.getElementById('sn-arena');
  const isC=Math.random()>.45;
  let pret,pp;
  if(isC){pret=p1(snV.p);pp=p1(snV.pp);}
  else{const d=shuf(snD.filter(x=>x.i!==snV.i))[0];pret=p1(d.p);pp=p1(d.pp);}
  const el=document.createElement('div');el.className='fw';
  // BOTH forms visible on the falling item
  el.innerHTML=`<span class="fw-pret">${pret}</span><span class="fw-pp">${pp}</span>`;
  el.style.left=Math.max(6,Math.random()*(arena.clientWidth-130))+'px';el.style.top='-70px';
  arena.appendChild(el);
  let top=-70;const spd=2.0+(snSc*.05);
  const fi=setInterval(()=>{top+=spd;el.style.top=top+'px';
    if(top>arena.clientHeight){clearInterval(fi);el.remove();
      if(isC){snLv--;updSnLv();toast('💔 Raté ! '+pret+' / '+pp,'ko');
        if(snLv<=0){stopSniper();showR(snSc,'🎯 Score final',startSniper,'var(--c3)');}else nextSn();}
    }},20);
  snFIs.push(fi);
  el.addEventListener('click',()=>{clearInterval(fi);el.remove();
    if(isC){snSc++;document.getElementById('sn-sc').textContent=snSc;toast('🎯 +1','ok');nextSn();}
    else{snLv--;updSnLv();toast('💔 Faux !','ko');if(snLv<=0){stopSniper();showR(snSc,'🎯 Score final',startSniper,'var(--c3)');}}
  });
}

// ═════════ MEMORY ═════════
let memP=4,memC=[],memF=[],memMt=0,memMv=0,memLk=false;
function startMem(pairs,btn){
  memP=pairs;memMt=0;memMv=0;memF=[];memLk=false;
  if(btn){document.querySelectorAll('.mem-ctrl .mb').forEach(b=>b.classList.remove('active'));btn.classList.add('active');}
  document.getElementById('mm-mv').textContent=0;document.getElementById('mm-fd').textContent=0;document.getElementById('mm-tt').textContent=pairs;
  const sel=shuf([...V]).slice(0,pairs);
  // LEFT: infinitif, RIGHT: pret+pp pair
  memC=shuf([
    ...sel.map((v,i)=>({id:i,type:'inf',text:v.i.replace('to ',''),pair:i})),
    ...sel.map((v,i)=>({id:i+pairs,type:'both',pretText:p1(v.p),ppText:p1(v.pp),pair:i}))
  ]);
  const grid=document.getElementById('mgrid');
  grid.className='mgrid '+(pairs<=4?'g4':pairs<=8?'g8':'g12');
  grid.innerHTML=memC.map((c,idx)=>`
    <div class="mcard" id="mc${idx}" onclick="flipMem(${idx})">
      <div class="mf"><div class="mi">🔤</div></div>
      <div class="mb">
        <div class="mct">${c.type==='inf'?'INFINITIF':'PRÉT + PP'}</div>
        <div class="mcv">${c.type==='inf'?c.text:`<span class="pret-c">${c.pretText}</span><br><span class="pp-c">${c.ppText}</span>`}</div>
      </div>
    </div>`).join('');
}
function flipMem(idx){
  if(memLk)return;const el=document.getElementById('mc'+idx);
  if(el.classList.contains('flipped')||el.classList.contains('matched'))return;
  el.classList.add('flipped');memF.push(idx);
  if(memF.length===2){
    memMv++;document.getElementById('mm-mv').textContent=memMv;memLk=true;
    const[a,b]=memF;
    if(memC[a].pair===memC[b].pair&&memC[a].type!==memC[b].type){
      setTimeout(()=>{document.getElementById('mc'+a).classList.add('matched');document.getElementById('mc'+b).classList.add('matched');memMt++;document.getElementById('mm-fd').textContent=memMt;toast('✅ Paire !','ok');memF=[];memLk=false;if(memMt===memP)showR(memMv,'coups 🧩',()=>startMem(memP,null),'var(--c4)');},400);
    }else{setTimeout(()=>{document.getElementById('mc'+a).classList.remove('flipped');document.getElementById('mc'+b).classList.remove('flipped');memF=[];memLk=false;},850);}
  }
}

