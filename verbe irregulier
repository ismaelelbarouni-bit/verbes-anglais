// helpers
function shuf(a){const b=[...a];for(let i=b.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[b[i],b[j]]=[b[j],b[i]];}return b;}
function norm(s){return s.trim().toLowerCase().replace(/\s*\(.*?\)/g,'').replace(/\s+/g,' ').split('/')[0].trim();}
function matchV(inp,correct){return correct.split('/').map(s=>norm(s)).includes(norm(inp));}
function p1(s){return s.split('/')[0].trim();}// first form

