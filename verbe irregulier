function initChain(){chD=shuf([...V]);chI=0;chS=0;document.getElementById('ch-sc').textContent=0;renderChain();}
function renderChain(){
  if(chI>=chD.length){showR(chS,'verbes corrects 🔗',initChain,'var(--c8)');return;}
  const v=chD[chI];chSl=[null,null,null];chSel=null;
  document.getElementById('ch-w').textContent='';document.getElementById('ch-f').textContent='Sens : '+v.fr;
  document.getElementById('ch-idx').textContent=chI+1;document.getElementById('ch-tot').textContent=chD.length;
  document.getElementById('ch-pr').style.width=((chI/chD.length)*100)+'%';
  document.getElementById('ch-fb').textContent='';
  [0,1,2].forEach(i=>{document.getElementById('cs'+i).className='cslot';document.getElementById('csv'+i).textContent='—';});
  const forms=shuf([
    {label:v.i.replace('to ',''),full:v.i,pos:0,sub:''},
    {label:p1(v.p),full:v.p,pos:1,sub:'prétérit'},
    {label:p1(v.pp),full:v.pp,pos:2,sub:'PP'}
  ]);
  document.getElementById('ctiles').innerHTML=forms.map((f,i)=>`
    <div class="ctile" id="ct${i}" draggable="true" ondragstart="dS(event,${i})" onclick="tTile(${i})" data-pos="${f.pos}" data-full="${f.full}">
      ${f.label}${f.sub?`<div class="ct-sub">${f.sub}</div>`:''}
    </div>`).join('');
}
function dS(e,i){document.getElementById('ct'+i).classList.add('dragging');e.dataTransfer.setData('text',i);}
function aD(e){e.preventDefault();e.target.closest('.cslot')?.classList.add('drag-over');}
function dT(e,si){e.preventDefault();e.target.closest('.cslot')?.classList.remove('drag-over');placeTile(parseInt(e.dataTransfer.getData('text')),si);}
function tTile(i){const t=document.getElementById('ct'+i);if(t.classList.contains('used'))return;if(chSel===i){chSel=null;t.classList.remove('selected');return;}document.querySelectorAll('.ctile').forEach(x=>x.classList.remove('selected'));chSel=i;t.classList.add('selected');}
function tS(si){if(chSel===null)return;placeTile(chSel,si);chSel=null;}
function placeTile(ti,si){
  const t=document.getElementById('ct'+ti);if(!t||t.classList.contains('used'))return;
  if(chSl[si]!==null){const prev=document.getElementById('ct'+chSl[si]);if(prev)prev.classList.remove('used','selected');}
  chSl[si]=ti;t.classList.add('used');t.classList.remove('selected');
  document.getElementById('cs'+si).className='cslot filled';
  // show label only (first line)
  document.getElementById('csv'+si).textContent=t.childNodes[0].textContent.trim();
}
function clearCh(){chSl=[null,null,null];document.querySelectorAll('.ctile').forEach(t=>t.classList.remove('used','selected'));[0,1,2].forEach(i=>{document.getElementById('cs'+i).className='cslot';document.getElementById('csv'+i).textContent='—';});chSel=null;}
function checkCh(){
  if(chSl.includes(null)){toast('Place les 3 !','ko');return;}
  const v=chD[chI];const exp=[v.i,v.p,v.pp];let ok=true;
  chSl.forEach((ti,si)=>{const t=document.getElementById('ct'+ti);const isOk=exp[si].split('/').map(s=>norm(s)).includes(norm(t.dataset.full));document.getElementById('cs'+si).className='cslot '+(isOk?'correct':'wrong');if(!isOk)ok=false;});
  if(ok){chS++;document.getElementById('ch-sc').textContent=chS;toast('🔗 Parfait !','ok');chI++;setTimeout(renderChain,650);}
  else{document.getElementById('ch-fb').innerHTML=`Correct : <strong style="color:var(--c2)">${v.i} → ${v.p} → ${v.pp}</strong>`;setTimeout(()=>{chI++;renderChain();},1900);}
}
function skipCh(){chI++;renderChain();}

// ═════════ TRANS ═════════
let trD=[],trI=0,trG=0,trB=0,trMode='fr2en';
function initTrans(){trD=shuf([...V]);trI=0;trG=0;trB=0;updTr();renderTr();}
function toggleTrMode(){trMode=trMode==='fr2en'?'en2fr':'fr2en';document.getElementById('tr-mb').textContent='🔄 Mode : '+(trMode==='fr2en'?'FR→EN':'EN→FR');initTrans();}
function renderTr(){
  if(trI>=trD.length){showR(trG,'bonnes traductions 🌍',initTrans,'var(--c5)');return;}
  const v=trD[trI];
  document.getElementById('tr-pr').style.width=((trI/trD.length)*100)+'%';document.getElementById('tr-i').textContent=trI+1;
  ['tr-inf','tr-pr','tr-pp'].forEach(id=>{const el=document.getElementById(id);el.value='';el.className='tinp';});
  document.getElementById('tr-fb').innerHTML='';
  if(trMode==='fr2en'){document.getElementById('tr-dir').textContent='🇫🇷 Français → 🇬🇧 Anglais';document.getElementById('tr-ql').textContent='SENS EN FRANÇAIS — DONNE LES 3 FORMES';document.getElementById('tr-q').textContent=v.fr.toUpperCase();document.getElementById('tr-h').textContent='';document.getElementById('tr-l0').textContent='Infinitif anglais';}
  else{document.getElementById('tr-dir').textContent='🇬🇧 Anglais → Trad. + formes';document.getElementById('tr-ql').textContent='INFINITIF ANGLAIS — TRADUIS + PRÉT + PP';document.getElementById('tr-q').textContent=v.i.toUpperCase();document.getElementById('tr-h').textContent=v.fr;document.getElementById('tr-l0').textContent='Traduction française';}
  document.getElementById('tr-inf').focus();
}
function trK(e){if(e.key==='Enter'){const ids=['tr-inf','tr-pr','tr-pp'];const ci=ids.indexOf(document.activeElement.id);if(ci<2)document.getElementById(ids[ci+1]).focus();else checkTr();}}
function checkTr(){
  const v=trD[trI];
  const inf=document.getElementById('tr-inf').value,pret=document.getElementById('tr-pr').value,pp=document.getElementById('tr-pp').value;
  let ok0,ok1=matchV(pret,v.p),ok2=matchV(pp,v.pp);
  if(trMode==='fr2en')ok0=matchV(inf,v.i)||norm(inf)===norm(v.i.replace('to ',''));
  else ok0=norm(inf).split(' ').some(w=>norm(v.fr).includes(w))||norm(inf)===norm(v.fr);
  document.getElementById('tr-inf').className='tinp '+(ok0?'ok':'ko');
  document.getElementById('tr-pr').className='tinp '+(ok1?'ok':'ko');
  document.getElementById('tr-pp').className='tinp '+(ok2?'ok':'ko');
  if(ok0&&ok1&&ok2)trG++;else trB++;updTr();
  document.getElementById('tr-fb').innerHTML=`<span>INF: <strong>${v.i}</strong></span><span>PRÉT: <strong>${v.p}</strong></span><span>PP: <strong>${v.pp}</strong></span><span>FR: <strong>${v.fr}</strong></span>`;
  toast((ok0&&ok1&&ok2)?'🌍 Parfait !':'❌ Voir correction',(ok0&&ok1&&ok2)?'ok':'ko');
  setTimeout(()=>{trI++;renderTr();},(ok0&&ok1&&ok2)?750:2100);
}
function skipTr(){trI++;renderTr();}
function updTr(){document.getElementById('tr-gd').textContent=trG;document.getElementById('tr-bd').textContent=trB;document.getElementById('tr-i').textContent=trI+1;}

// ═════════ QCM — choices always show BOTH forms ═════════
let qD=[],qI=0,qG=0,qStr=0,qRec=0,qMd='pret',qLk=false;
function initQCM(){qD=shuf([...V]);qI=0;qG=0;qStr=0;qRec=0;qLk=false;['qg','qs','qr'].forEach(id=>document.getElementById(id).textContent=0);renderQCM();}
function setQM(m,el){qMd=m;document.querySelectorAll('.qmodes .mb').forEach(b=>b.classList.remove('active'));el.classList.add('active');initQCM();}
function renderQCM(){
  if(qI>=qD.length){showR(qG,'bonnes réponses 🎲',initQCM,'var(--c6)');return;}
  qLk=false;const v=qD[qI];
  const m=qMd==='mix'?['pret','inf','fr'][Math.floor(Math.random()*3)]:qMd;
  let question,hint;
  if(m==='pret'||m==='inf'){question=m==='pret'?v.i+' →':v.fr+' →';hint=m==='pret'?v.fr:'Inf: '+v.i;}
  else{question=v.fr.toUpperCase();hint='Infinitif : '+v.i;}
  document.getElementById('q-lab').textContent=m==='fr'?'INFINITIF + FORMES DE':'PRÉTÉRIT + PP DE';
  document.getElementById('q-q').textContent=question;document.getElementById('q-h').textContent=hint;
  document.getElementById('qp').style.width=((qI/qD.length)*100)+'%';
  // Build choices — each shows BOTH pret+pp
  const others=shuf(qD.filter(x=>x.i!==v.i)).slice(0,3);
  const allChoices=shuf([v,...others]);
  document.getElementById('q-ch').innerHTML=allChoices.map(c=>`
    <div class="qch" onclick="checkQCM(this,'${c.i.replace(/'/g,"\\'")}','${v.i.replace(/'/g,"\\'")}')">
      <div class="ch-pret">${p1(c.p)}</div>
      <div class="ch-pp">PP: ${p1(c.pp)}</div>
    </div>`).join('');
}
function checkQCM(el,chosen,correct){
  if(qLk)return;qLk=true;
  const ok=chosen===correct;
  document.querySelectorAll('.qch').forEach(b=>{b.classList.add('dis');if(b.onclick&&b.getAttribute('onclick').includes(correct.replace(/'/g,"\\'")))b.classList.add('correct');});
  if(!ok)el.classList.add('wrong');
  if(ok){qG++;qStr++;if(qStr>qRec)qRec=qStr;toast('🎲 +1','ok');}else{qStr=0;toast('❌','ko');}
  document.getElementById('qg').textContent=qG;document.getElementById('qs').textContent=qStr;document.getElementById('qr').textContent=qRec;
  setTimeout(()=>{qI++;renderQCM();},ok?550:1500);
}

// ═════════ PENDU — partner form shown as hint ═════════
const PDP=['pdh','pdb','pdla','pdra','pdll','pdrl','pdfc'];
let pdD=[],pdI=0,pdW=0,pdL=0,pdMd='pret',pdWord='',pdGuessed=[],pdErrors=0;
function initPendu(){pdD=shuf([...V]);pdI=0;pdW=0;pdL=0;document.getElementById('pw').textContent=0;document.getElementById('pl').textContent=0;newPG();}
function setPM(m,el){pdMd=m;document.querySelectorAll('.pd-modes .mb').forEach(b=>b.classList.remove('active'));el.classList.add('active');initPendu();}
function newPG(){
  if(pdI>=pdD.length)pdD=shuf([...V]),pdI=0;
  const v=pdD[pdI++];
  // word to guess
  pdWord=pdMd==='pret'?p1(v.p).toLowerCase():pdMd==='pp'?p1(v.pp).toLowerCase():v.i.replace('to ','').trim().toLowerCase();
  // partner = the OTHER form (always show it as hint to create the link)
  const partner=pdMd==='pret'?'PP : '+p1(v.pp):pdMd==='pp'?'Prét : '+p1(v.p):'Prét : '+p1(v.p)+' / PP : '+p1(v.pp);
  pdGuessed=[];pdErrors=0;
  const lbl=pdMd==='pret'?'DEVINE LE PRÉTÉRIT':pdMd==='pp'?'DEVINE LE PARTICIPE PP':'DEVINE L\'INFINITIF (sans "to")';
  document.getElementById('pd-lab').textContent=lbl;
  document.getElementById('pd-fr').textContent=v.fr.toUpperCase();
  document.getElementById('pd-ex').textContent=pdMd!=='inf'?'Infinitif : '+v.i:'';
  // ALWAYS show the partner form — creates the memory link
  document.getElementById('pd-partner').style.display='inline-flex';
  document.getElementById('pd-part-val').textContent=partner;
  document.getElementById('pd-i').textContent=pdI;document.getElementById('pd-t').textContent=pdD.length;
  PDP.forEach(id=>document.getElementById(id).style.display='none');
  renderPdW();buildPdKB();document.getElementById('pd-e').textContent=0;
}
function renderPdW(){
  const wd=document.getElementById('pd-wd');wd.innerHTML='';
  for(const ch of pdWord){
    if(ch===' '){const s=document.createElement('div');s.className='pl sp';wd.appendChild(s);}
    else{const d=document.createElement('div');d.className='pl'+(pdGuessed.includes(ch)?' rev':'');d.textContent=pdGuessed.includes(ch)?ch:'';wd.appendChild(d);}
  }
}
function buildPdKB(){
  const kb=document.getElementById('pd-kb');kb.innerHTML='';
  'abcdefghijklmnopqrstuvwxyz'.split('').forEach(l=>{
    const b=document.createElement('button');b.className='pk';b.textContent=l;b.id='pk'+l;
    b.onclick=()=>pdGuess(l);kb.appendChild(b);
  });
}
function pdGuess(l){
  const btn=document.getElementById('pk'+l);if(!btn||btn.classList.contains('uok')||btn.classList.contains('uko'))return;
  if(pdWord.includes(l)){pdGuessed.push(l);btn.classList.add('uok');renderPdW();
    const done=[...new Set(pdWord.split('').filter(c=>c!==' '))].every(c=>pdGuessed.includes(c));
    if(done){pdW++;document.getElementById('pw').textContent=pdW;toast('🎉 Bravo !','ok');setTimeout(newPG,1100);}
  }else{pdErrors++;btn.classList.add('uko');if(pdErrors<=PDP.length)document.getElementById(PDP[pdErrors-1]).style.display='';document.getElementById('pd-e').textContent=pdErrors;
    if(pdErrors>=7){pdL++;document.getElementById('pl').textContent=pdL;toast('💀 C\'était : '+pdWord,'ko');
      document.querySelectorAll('.pl:not(.sp):not(.rev)').forEach(el=>el.classList.add('wrev'));
      setTimeout(newPG,2000);}
  }
}

